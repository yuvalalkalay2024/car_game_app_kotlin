<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="#FFF"
    android:layoutDirection="ltr"
    tools:ignore="NestedWeights">

    <LinearLayout
        android:id="@+id/layout_hearts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:padding="8dp"
        android:orientation="horizontal"
        android:contentDescription="@string/heart"
        >
        <TextView
            android:id="@+id/tv_coins"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Coins: 0"
            android:textSize="24sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
        <TextView
            android:id="@+id/tv_distance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dist: 0m"
            android:textSize="18sp"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:textStyle="bold"/>
        <ImageView
            android:id="@+id/heart_1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:src="@drawable/heart"
            android:contentDescription="@string/heart_1"
            />
        <ImageView
            android:id="@+id/heart_2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:src="@drawable/heart"
            android:contentDescription="@string/heart_2"

            />
        <ImageView
            android:id="@+id/heart_3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:src="@drawable/heart"
            android:contentDescription="@string/heart_3"

            />
    </LinearLayout>

